#include "resource.h"

IDI_APP_ICON ICON "assets\\logo_solid.ico"

1 VERSIONINFO
 FILEVERSION 1,1,1,0
 PRODUCTVERSION 1,1,1,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Krevon Studios"
            VALUE "FileDescription", "Krevon Station"
            VALUE "FileVersion", "1.1.1"
            VALUE "InternalName", "Krevon Station"
            VALUE "OriginalFilename", "Krevon Station.exe"
            VALUE "ProductName", "Krevon Station"
            VALUE "ProductVersion", "1.1.1"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END


